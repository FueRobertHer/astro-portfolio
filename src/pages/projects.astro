---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { projects } from "../data/projects";
---

<BaseLayout
  title="Projects | Fue Her"
  description="Selected projects by Fue Her, including Astro sites, browser extensions, JavaScript applications, and product-focused web experiments."
>
  <main class="py-12 sm:py-20">
    <section class="max-w-3xl">
      <p class="text-sm font-bold uppercase text-[#C63D32]">
        Selected work
      </p>
      <h1 class="mt-3 text-4xl font-black text-stone-950 sm:text-5xl dark:text-stone-50">
        Projects shaped by product thinking and hands-on engineering.
      </h1>
      <p class="mt-5 text-lg leading-8 text-stone-600 dark:text-stone-300">
        A mix of portfolio work, Astro sites, browser extensions, games, and
        application experiments. The through-line is practical: build the thing,
        learn from the constraints, and make the next version clearer.
      </p>
    </section>

    <section class="mt-10 grid gap-5 lg:grid-cols-2" aria-label="Project list">
      {projects.map((project) => <ProjectCard project={project} />)}
    </section>
  </main>
</BaseLayout>
