---
import BaseLayout from "../layouts/BaseLayout.astro";
import ButtonLink from "../components/ButtonLink.astro";
import CurrentlyPanel from "../components/CurrentlyPanel.astro";
import ProjectCard from "../components/ProjectCard.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { featuredProjects } from "../data/projects";
---

<BaseLayout
  title="Fue Her | Full Stack Engineer"
  description="Fue Her is a full-stack engineer building reliable, accessible web products with Astro, React, TypeScript, and practical product judgment."
>
  <main class="pb-16">
    <section class="grid min-h-[70vh] items-center gap-10 py-12 sm:grid-cols-[1.08fr_0.92fr] sm:py-20">
      <div class="max-w-3xl">
        <p class="text-sm font-bold uppercase text-[#C63D32]">
          Full Stack Engineer
        </p>
        <h1 class="mt-4 max-w-4xl text-5xl font-black leading-tight text-stone-950 sm:text-6xl dark:text-stone-50">
          Fue Her builds reliable web products with care.
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-stone-600 dark:text-stone-300">
          I work across frontend and backend systems, with a focus on accessible
          interfaces, practical architecture, and the kind of details that make
          software easier to use and maintain.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <ButtonLink href="/projects">View Projects</ButtonLink>
          <ButtonLink href="mailto:fueroberther@gmail.com" variant="secondary">
            Contact Me
          </ButtonLink>
        </div>
        <div class="mt-8">
          <SocialLinks />
        </div>
      </div>

      <CurrentlyPanel />
    </section>

    <section class="border-t border-stone-300 py-12 dark:border-stone-800">
      <div class="flex flex-col justify-between gap-4 sm:flex-row sm:items-end">
        <div>
          <p class="text-sm font-bold uppercase text-[#C63D32]">
            Selected work
          </p>
          <h2 class="mt-2 text-3xl font-black text-stone-950 dark:text-stone-50">
            Recent and representative projects
          </h2>
        </div>
        <ButtonLink href="/projects" variant="ghost" class="w-fit">
          See all projects
        </ButtonLink>
      </div>

      <div class="mt-8 grid gap-4 lg:grid-cols-3">
        {featuredProjects.map((project) => <ProjectCard project={project} compact />)}
      </div>
    </section>
  </main>
</BaseLayout>
