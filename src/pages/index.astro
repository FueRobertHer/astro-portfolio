---
import BaseLayout from "../layouts/BaseLayout.astro";
import CurrentlyPanel from "../components/CurrentlyPanel.astro";
import SocialLinks from "../components/SocialLinks.astro";
---

<BaseLayout
  title="Fue Her | Full Stack Engineer"
  description="Fue Her is a full-stack engineer building reliable, accessible web products with Astro, React, TypeScript, and practical product judgment."
>
  <main>
    <section class="grid items-center gap-8 py-8 sm:grid-cols-[1.08fr_0.92fr] sm:py-12 lg:py-14">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase text-[#C63D32] sm:text-sm">
          Full Stack Engineer
        </p>
        <h1 class="mt-3 max-w-3xl text-4xl font-black leading-tight text-stone-950 sm:text-5xl dark:text-stone-50">
          Fue Her builds reliable web products with care.
        </h1>
        <p class="mt-4 max-w-2xl text-base leading-7 text-stone-600 sm:text-lg dark:text-stone-300">
          I work across frontend and backend systems, with a focus on accessible
          interfaces, practical architecture, and the kind of details that make
          software easier to use and maintain.
        </p>
        <div class="mt-5">
          <SocialLinks />
        </div>
      </div>

      <CurrentlyPanel />
    </section>
  </main>
</BaseLayout>
