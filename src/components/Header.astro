---
import Logo from "./Logo.astro";
import NavLink from "./NavLink.astro";
import Menu from "./Menu";
import ThemeToggleButton from "./ThemeToggleButton";

interface Link {
  text: string;
  href: string;
}

const links: Link[] = [
  {
    text: "Home",
    href:"/"
  },
  {
    text: "About",
    href:"/about"
  }
]
---
<header class="flex w-full items-center justify-between px-5 py-3 sm:px-8">
  <a class="size-8" href="/" aria-label="Fue Her home">
    <Logo />
  </a>
  <div class="hidden items-center justify-between sm:flex sm:w-fit sm:justify-normal">
    {links.map(link => (
      <span class="mx-4">
        <NavLink href={link.href}>
          {link.text}
        </NavLink>
      </span>
    ))}
    <span class="mx-4">
      <ThemeToggleButton client:visible />
    </span>
  </div>
  <div class="sm:hidden">
    <Menu client:visible>
      <menu class="flex flex-col items-center gap-4 text-lg">
        <div>
          <ThemeToggleButton client:visible />
        </div>
        {links.map(link => (
          <div>
            <NavLink href={link.href}>
              {link.text}
            </NavLink>
          </div>
        ))}
      </menu>
    </Menu>
  </div>
</header>
