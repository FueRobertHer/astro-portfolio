---
export interface Props {
  href: string;
  variant?: "primary" | "secondary" | "ghost";
  target?: string;
  class?: string;
}

const {
  href,
  variant = "primary",
  target,
  class: className = "",
} = Astro.props;

const isExternal = href.startsWith("http");
const rel = target === "_blank" || isExternal ? "noopener noreferrer" : undefined;

const variants = {
  primary:
    "border-[#366CC6] bg-[#366CC6] text-white hover:border-[#C63D32] hover:bg-[#C63D32] dark:border-[#C63D32] dark:bg-[#C63D32] dark:hover:border-[#366CC6] dark:hover:bg-[#366CC6]",
  secondary:
    "border-stone-500 text-stone-800 hover:border-[#366CC6] hover:text-[#366CC6] dark:border-stone-500 dark:text-stone-100 dark:hover:border-[#C63D32] dark:hover:text-[#C63D32]",
  ghost:
    "border-transparent text-stone-700 hover:text-[#366CC6] dark:text-stone-200 dark:hover:text-[#C63D32]",
};
---

<a
  href={href}
  target={target}
  rel={rel}
  class={`inline-flex min-h-11 items-center justify-center rounded-md border px-4 py-2 text-sm font-bold transition-colors focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-[#366CC6] dark:focus-visible:outline-[#C63D32] ${variants[variant]} ${className}`}
>
  <slot />
</a>
