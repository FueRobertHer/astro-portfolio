---
const props = Astro.props
const href = props.href ?? "";
const isExternal = href.startsWith("http");
const rel = props.rel ?? (props.target === "_blank" || isExternal ? "noopener noreferrer" : undefined);
---
<a class=`text-blue-700 underline-offset-4 hover:text-blue-400 hover:underline dark:text-blue-200 dark:hover:text-blue-400 ${props.class ?? ""}` href={props.href} target={props.target} rel={rel}>
  <slot/>
</a>
